{
  "name": "clustercodex",
  "author": {
    "name": "Justin Law",
    "email": "justinthelaw@gmail.com"
  },
  "engines": {
    "node": "25.6.1"
  },
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --experimental-build-mode compile",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "PRE_COMMIT_HOME=/tmp/pre-commit-cache pre-commit run --all-files --hook-stage pre-commit",
    "test": "npm run test:e2e",
    "infra:start": "./scripts/start-infra.sh",
    "infra:stop": "./scripts/stop-infra.sh",
    "test:e2e": "npm run infra:stop && npm run infra:start && ./scripts/test-e2e.sh",
    "clean": "./scripts/clean.sh",
    "flight-check": "npm run clean && npm install && npm run lint && npm run build && npm run test",
    "postinstall": "playwright install --with-deps"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.5.4"
  }
}
