{
  "name": "clustercodex",
  "author": {
    "name": "Justin Law",
    "email": "justinthelaw@gmail.com"
  },
  "engines": {
    "node": "25.6.1"
  },
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "./scripts/stop-infra.sh && ./scripts/start-infra.sh && next dev",
    "build": "next build --experimental-build-mode compile",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "PRE_COMMIT_HOME=/tmp/pre-commit-cache pre-commit run --all-files --hook-stage pre-commit",
    "test": "./scripts/start-infra.sh && ./scripts/test-e2e.sh && ./scripts/stop-infra.sh",
    "infra:start": "./scripts/start-infra.sh",
    "infra:stop": "./scripts/stop-infra.sh",
    "clean": "./scripts/clean.sh && ./scripts/stop-infra.sh",
    "flight-check": "npm run clean && npm install && npm run lint && npm run build && npm run test",
    "postinstall": "playwright install --with-deps && if [ ! -f .env ]; then cp .env.example .env; fi"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@openai/codex-sdk": "^0.107.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/postcss": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.5.4"
  }
}
