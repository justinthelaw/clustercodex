# Namespace where K8sGPT operator writes Result CRDs
K8SGPT_NAMESPACE=k8sgpt-operator-system

# Optional explicit kubeconfig path (defaults to ~/.kube/config)
# KUBECONFIG=~/.kube/config

# Optional explicit kube context override
# KUBE_CONTEXT=k3d-clustercodex

# Codex model for live plan generation
CODEX_MODEL=gpt-5.3-codex

# Codex auth mode: chatgpt | api | auto
CODEX_AUTH_MODE=chatgpt

# Optional safety limits for live plan generation
# CODEX_PLAN_TIMEOUT_MS=90000
# CODEX_PLAN_CONTEXT_MAX_CHARS=12000

# API key for `CODEX_AUTH_MODE=api` or OpenAI-compatible providers
# CODEX_API_KEY=

# Optional OpenAI-compatible base URL override (for self-hosted gateways/servers)
# CODEX_BASE_URL=

# Local provider mode selector: none | ollama | lmstudio | llama-server | custom
CODEX_LOCAL_PROVIDER=none

# Required when CODEX_LOCAL_PROVIDER is not "none"
# CODEX_LOCAL_BASE_URL=
# CODEX_LOCAL_PROVIDER_ID=
# CODEX_LOCAL_PROVIDER_NAME=
# CODEX_LOCAL_ENV_KEY=
# CODEX_LOCAL_API_KEY=
